{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["js/**/*.js", "tests/**/*.js", "scripts/**/*.mjs"],
  "exclude": ["legacy", "node_modules", "coverage", "_site"]
}
